# ─── MoneyMotion ─────────────────────────────────────────────────────────────
# Your MoneyMotion API key — found in your dashboard under Development → API Keys
MONEYMOTION_API_KEY=your_moneymotion_api_key_here

# Your MoneyMotion webhook secret — found when you create a webhook in the dashboard
MONEYMOTION_WEBHOOK_SECRET=your_moneymotion_webhook_secret_here

# ─── SellAuth ────────────────────────────────────────────────────────────────
# Your SellAuth API key — found at Dashboard > Account > API Access
SELLAUTH_API_KEY=your_sellauth_api_key_here

# Your SellAuth shop ID — found on the same API Access page
SELLAUTH_SHOP_ID=your_sellauth_shop_id_here

# ─── Server ──────────────────────────────────────────────────────────────────
# The public URL of this server (no trailing slash)
# Example: https://your-app.up.railway.app
DOMAIN=https://your-domain.com

# Set to "true" to use MoneyMotion sandbox (test mode). Remove or set to "false" for live payments.
SANDBOX=false

# Port (Railway sets this automatically — leave it unless you know what you're doing)
# PORT=3000
